{
  "name": "test-frontend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "react-router dev",
    "build": "react-router build",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc --noEmit",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "lint:ci": "eslint . --report-unused-disable-directives --format json",
    "lint/fix": "eslint . --fix",
    "format/check": "prettier . --check",
    "format/fix": "prettier . --write",
    "orval": "orval --config ./orval.config.cjs",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "coverage": "vitest run --coverage",
    "coverage:ci": "vitest run --coverage"
  },
  "dependencies": {
    "@opentelemetry/api": "1.9.1",
    "@opentelemetry/auto-instrumentations-node": "0.72.0",
    "@opentelemetry/auto-instrumentations-web": "0.59.0",
    "@opentelemetry/context-zone": "2.6.1",
    "@opentelemetry/exporter-logs-otlp-http": "0.214.0",
    "@opentelemetry/exporter-metrics-otlp-http": "0.214.0",
    "@opentelemetry/exporter-trace-otlp-http": "0.214.0",
    "@opentelemetry/instrumentation": "0.214.0",
    "@opentelemetry/resources": "2.6.1",
    "@opentelemetry/sdk-logs": "0.214.0",
    "@opentelemetry/sdk-metrics": "2.6.1",
    "@opentelemetry/sdk-node": "0.214.0",
    "@opentelemetry/sdk-trace-base": "2.6.1",
    "@opentelemetry/sdk-trace-web": "2.6.1",
    "@opentelemetry/semantic-conventions": "1.40.0",
    "@react-router/node": "7.14.0",
    "@react-router/serve": "7.14.0",
    "@tailwindcss/vite": "4.2.2",
    "@tanstack/react-query": "5.97.0",
    "@tanstack/react-query-devtools": "5.97.0",
    "axios": "1.15.0",
    "ioredis": "5.10.1",
    "isbot": "5.1.37",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-router": "7.14.0",
    "tailwindcss": "4.2.2"
  },
  "devDependencies": {
    "@cspell/eslint-plugin": "10.0.0",
    "@eslint/js": "10.0.1",
    "@faker-js/faker": "10.4.0",
    "@react-router/dev": "7.14.0",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "8.58.1",
    "@typescript-eslint/parser": "8.58.1",
    "@vitest/coverage-istanbul": "4.1.4",
    "@vitest/ui": "4.1.4",
    "eslint": "10.2.0",
    "eslint-config-love": "152.0.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-formatter-compact": "9.0.1",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsdoc": "62.9.0",
    "eslint-plugin-n": "17.24.0",
    "eslint-plugin-perfectionist": "5.8.0",
    "eslint-plugin-prettier": "5.5.4",
    "eslint-plugin-promise": "7.2.1",
    "eslint-plugin-sonarjs": "4.0.2",
    "jsdom": "29.0.2",
    "msw": "2.13.2",
    "openapi-types": "12.1.3",
    "orval": "8.7.0",
    "prettier": "3.8.2",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.0",
    "vite": "8.0.8",
    "vite-plugin-mkcert": "2.0.0",
    "vitest": "4.1.4"
  }
}
