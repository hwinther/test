{
  "name": "test-frontend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "react-router dev",
    "build": "react-router build",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc --noEmit",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "lint:ci": "eslint . --report-unused-disable-directives --format json",
    "lint/fix": "eslint . --fix",
    "format/check": "prettier . --check",
    "format/fix": "prettier . --write",
    "orval": "orval --config ./orval.config.cjs",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "coverage": "vitest run --coverage",
    "coverage:ci": "vitest run --coverage"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.71.0",
    "@opentelemetry/auto-instrumentations-web": "^0.58.0",
    "@opentelemetry/context-zone": "^2.6.1",
    "@opentelemetry/exporter-logs-otlp-http": "^0.213.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.213.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.213.0",
    "@opentelemetry/instrumentation": "^0.213.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-logs": "^0.213.0",
    "@opentelemetry/sdk-metrics": "^2.6.1",
    "@opentelemetry/sdk-node": "^0.213.0",
    "@opentelemetry/sdk-trace-base": "^2.6.1",
    "@opentelemetry/sdk-trace-web": "^2.6.1",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@react-router/node": "7.13.1",
    "@react-router/serve": "7.13.1",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-query": "5.95.2",
    "@tanstack/react-query-devtools": "5.95.2",
    "axios": "1.13.6",
    "ioredis": "^5.10.1",
    "isbot": "^5.1.35",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-router": "7.13.1",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@cspell/eslint-plugin": "9.4.0",
    "@eslint/js": "9.39.0",
    "@faker-js/faker": "10.4.0",
    "@react-router/dev": "7.13.1",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "^25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "8.50.0",
    "@typescript-eslint/parser": "8.50.0",
    "@vitest/coverage-istanbul": "4.1.1",
    "@vitest/ui": "4.1.1",
    "eslint": "9.39.0",
    "eslint-config-love": "140.0.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-formatter-compact": "9.0.1",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsdoc": "61.5.0",
    "eslint-plugin-n": "17.23.1",
    "eslint-plugin-perfectionist": "5.0.0",
    "eslint-plugin-prettier": "5.5.4",
    "eslint-plugin-promise": "7.2.1",
    "eslint-plugin-sonarjs": "3.0.7",
    "jsdom": "29.0.1",
    "msw": "2.12.14",
    "openapi-types": "12.1.3",
    "orval": "8.5.3",
    "prettier": "3.8.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.0",
    "vite": "^8.0.7",
    "vite-plugin-mkcert": "1.17.10",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "4.1.1"
  }
}
