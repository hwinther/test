# ── API ───────────────────────────────────────────────────────────────────────
# PUBLIC_* vars are injected into window.__TEST_PUBLIC__ at SSR time so the
# target can be changed without a rebuild (preferred in production / Kubernetes).
PUBLIC_API_BASE_URL=https://localhost:7156/

# VITE_* vars are baked into the client bundle at build time and act as a
# fallback when the window config is not yet available.
VITE_API_BASE_URL=https://localhost:7156/

# ── Redis (server-side / SSR only) ────────────────────────────────────────────
# Standard Redis URL format: redis://[:password@]host:port[/db]
# Override with credentials in .env.local — never commit passwords here.
REDIS_URL=redis://localhost:6379

# ── OpenTelemetry – Node / SSR ────────────────────────────────────────────────
# Disable the Node SDK in local dev to avoid connection errors when no
# collector is running. Set to false (or remove) in staging / production.
OTEL_SDK_DISABLED=true
OTEL_SERVICE_NAME=test-frontend-ssr
# Standard OTEL env var read by the Node SDK for all signals (traces/metrics/logs).
# Individual signal overrides: OTEL_EXPORTER_OTLP_TRACES_ENDPOINT, etc.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

# ── OpenTelemetry – browser ───────────────────────────────────────────────────
# PUBLIC_* are injected at runtime (preferred — no rebuild on change).
# PUBLIC_OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://otel-collector:4318/v1/traces
# PUBLIC_OTEL_SERVICE_NAME=test-frontend-web

# VITE_* are baked in at build time (fallback).
# VITE_OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://otel-collector:4318/v1/traces
# VITE_OTEL_SERVICE_NAME=test-frontend-web
